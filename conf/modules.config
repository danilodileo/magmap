/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename },
        enabled: false
    ]

    withName: FASTQC {
        ext.args = '--quiet'
        publishDir = [
            [
                path: { "${params.outdir}/fastqc" },
                mode: params.publish_dir_mode,
                pattern: "*.html"
            ]
        ]
    }

    withName: TRIMGALORE {
        ext.args = [
            '--fastqc',
            params.trim_reads > 0 ? "--nextseq ${params.trim_reads}" : ''
        ].join(' ').trim()
        publishDir = [
            [
                path: { "${params.outdir}/trimgalore/fastqc" },
                mode: params.publish_dir_mode,
                pattern: "*.html"
            ],
            [
                path: { "${params.outdir}/trimgalore" },
                mode: params.publish_dir_mode,
                pattern: "*.txt"
            ]
        ]
    }

    withName: GUNZIP_CONTIGS {
        publishDir = [
            enabled: false
        ]
    }

    withName: CAT_MANY {
        publishDir = [
            path: { "${params.outdir}/concatenate" },
            mode: params.publish_dir_mode,
            pattern: '*.gz',
            enabled: params.save_concatenated_genomes
        ]
    }

    withName: GENOMES2ORFS {
        ext.prefix = "magmap"
        publishDir = [
            path: { "${params.outdir}/summary_tables" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'BAM_SORT_STATS_SAMTOOLS:*' {
        publishDir = [
            enabled: false
        ]
    }

    withName: WGET_GENOME {
        storeDir = { "${params.genome_store_dir}" }
        errorStrategy = { task.attempt < 5 ? 'retry' : 'ignore' }
        maxRetries = 5
    }

    withName: PROKKA {
        ext.args = '--centre X --compliant'
        storeDir = { "${params.prokka_store_dir}" }
    }

    withName: PROKKAGFF2TSV {
        ext.prefix = "magmap"
        publishDir = [
            path: { "${params.outdir}/summary_tables" },
            mode: params.publish_dir_mode,
            pattern: "*.prokka-annotations.tsv.gz"
        ]
    }

    withName: 'KRAKEN2_DOWNLOAD_DB' {
        storeDir = { "${params.kraken2_store_dir}" }
    }

    withName: 'KRAKEN2_KRAKEN2' {
        ext.args = { params.kraken2_memory_mapping ? '--memory-mapping' : '' }
        publishDir = [
            [
                path: { "${params.outdir}/kraken2" },
                mode: params.publish_dir_mode,
                pattern: "*.{txt,report}"
            ],
            [
                path: { "${params.outdir}/kraken2" },
                mode: params.publish_dir_mode,
                pattern: "*.classified{,.gz}",
                enabled: params.kraken2_save_reads
            ]
        ]
    }

    withName: 'TAXBURST' {
        publishDir = [
            path: { "${params.outdir}/taxburst" },
            mode: params.publish_dir_mode,
            pattern: "*.html"
        ]
    }

    withName: 'SAMPLE_SKETCH' {
        ext.prefix = { "${meta.id}" }
        ext.args = "rna --param-string k=${params.sourmash_ksize}"
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            enabled: params.sourmash_save_sourmash
        ]
    }

    withName: 'GENOME_SKETCH' {
        ext.args = "rna --param-string k=${params.sourmash_ksize}"
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            enabled: params.sourmash_save_sourmash
        ]
    }

    withName: 'GENOME_INDEX' {
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            enabled: params.sourmash_save_sourmash
        ]
    }

    withName: 'SOURMASH_GATHER' {
        ext.prefix = { "${meta.id}" }
        ext.args = '--threshold-bp "50"'
        publishDir = [
            path: { "${params.outdir}/sourmash" },
            enabled: params.sourmash_save_sourmash
        ]
    }

    withName: 'SOURMASH_INDEX' {
        ext.prefix = "magmap"
        publishDir = [
            enabled: params.sourmash_save_sourmash
        ]
    }

    withName: BBMAP_ALIGN {
        ext.prefix = { "${meta.id}" }
        ext.args = { "trimreaddescriptions=t pigz=t minid=${params.bbmap_minid}" }
        publishDir = [
            [
                path: { "${params.outdir}/bbmap/bam" },
                mode: params.publish_dir_mode,
                pattern: "*.bam",
                enabled: params.bbmap_save_bam
            ],
            [
                path: { "${params.outdir}/bbmap/logs" },
                mode: params.publish_dir_mode,
                pattern: "*.log"
            ]
        ]
    }

    withName: BBMAP_INDEX {
        publishDir = [
            [
                path: { "${params.outdir}/bbmap/" },
                mode: params.publish_dir_mode,
                pattern: "*",
                enabled: params.bbmap_save_index
            ]
        ]
    }

    withName: SAMTOOLS_SORT {
        ext.prefix = { "${meta.id}.sorted" }
        publishDir = [
            pattern: "*.bam",
            enabled: false
        ]
    }

    withName: SAMTOOLS_INDEX {
        publishDir = [
            pattern: "*.bai",
            enabled: false
        ]
    }

    withName: '.*:FEATURECOUNTS' {
        ext.args = { "-g ID -t ${meta.feature} -F gtf" }
        ext.prefix = { "${meta.id}.${meta.feature}" }
        publishDir = [
            path: { "${params.outdir}/featurecounts" },
            mode: params.publish_dir_mode,
            pattern: "*.featureCounts.*"
        ]
    }

    withName: COLLECT_FEATURECOUNTS {
        ext.prefix = { "magmap.${meta.id}" }
        publishDir = [
            path: { "${params.outdir}/summary_tables" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: TIDYVERSE_JOINMETADATA {
        ext.prefix = "magmap"
        publishDir = [
            path: { "${params.outdir}/summary_tables" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: COLLECT_STATS {
        ext.prefix = "magmap"
        publishDir = [
            path: { "${params.outdir}/summary_tables" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: CUSTOM_DUMPSOFTWAREVERSIONS {
        publishDir = [
            path: { "${params.outdir}/pipeline_info" },
            mode: params.publish_dir_mode,
            pattern: '*_versions.yml'
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

}
