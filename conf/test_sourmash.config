/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/magmap -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile'
    config_profile_description = 'Minimal test dataset to check pipeline function'

    // Input data
    input             = params.pipelines_testdata_base_path + 'magmap/samplesheets/samplesheet.csv'
    indexes           = params.pipelines_testdata_base_path + 'magmap/testdata/sourmash_test.index.sbt.zip'
    genomeinfo        = params.pipelines_testdata_base_path + 'magmap/testdata/genometest.csv'
    //remote_genome_sources = params.pipelines_testdata_base_path + 'magmap/testdata/ncbi_assembly_summaries.txt'

    // Sourmash option
    sourmash       = true
}
