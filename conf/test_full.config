/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running full-size tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a full size pipeline test.

    Use as follows:
        nextflow run nf-core/magmap -profile test_full,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

params {
    config_profile_name        = 'Full test profile'
    config_profile_description = 'Full test dataset to check pipeline function'

    // Input data for full size test
    input            = params.pipelines_testdata_base_path + 'metatdenovo/samplesheet/samplesheet_full_test.csv'
    genomeinfo       = params.pipelines_testdata_base_path + 'magmap/testdata/genomes_full_test.csv'
    genome_store_dir = 's3://nf-core-awsmegatests/magmap/input/databases/genomes'
    prokka_store_dir = 's3://nf-core-awsmegatests/magmap/input/databases/prokka'
}
