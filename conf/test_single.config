/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Nextflow config file for running minimal tests
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Defines input files and everything required to run a fast and simple pipeline test.

    Use as follows:
        nextflow run nf-core/magmap -profile test,<docker/singularity> --outdir <OUTDIR>

----------------------------------------------------------------------------------------
*/

process {
    resourceLimits = [
        cpus: 4,
        memory: '15.GB',
        time: '1.h'
    ]
}

params {
    config_profile_name        = 'Test profile for mixed single/paired end data'
    config_profile_description = 'Minimal test dataset to check pipeline function with mixed single/paired end input'

    // Input data
    input           = params.pipelines_testdata_base_path + 'magmap/samplesheets/samplesheet_mixed_single_paired.csv'
    genomeinfo      = params.pipelines_testdata_base_path + 'magmap/testdata/genometest.csv'
    sequence_filter = params.pipelines_testdata_base_path + 'metatdenovo/test_data/rrna.fna.gz'

}
